# Локальный long polling (npm start)
#BOT_TOKEN= ваш токен пректа


# Cloudflare Worker + webhook (npm run deploy, см. комментарии в wrangler.toml)
# WEBHOOK_URL=https://<your-worker>.workers.dev/webhook
# WEBHOOK_SECRET=случайная_строка_для_проверки_заголовка

# Для wrangler dev скопируйте в .dev.vars (не коммитьте):
# BOT_TOKEN=...
# WEBHOOK_SECRET=...
# HTTPS-URL мини-приложения (кнопка Web App в /start). Пример после деплоя:
# MINI_APP_URL=https://<your-worker>.workers.dev/app/

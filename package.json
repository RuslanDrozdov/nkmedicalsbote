{
  "name": "telegram-survey-bot",
  "version": "1.0.0",
  "description": "Telegram bot: 2 screening questions, then 9 questions; optional Cloudflare Workers + D1",
  "main": "bot.js",
  "type": "module",
  "scripts": {
    "start": "node bot.js",
    "dev:worker": "wrangler dev",
    "build:mini-app": "npm run build --prefix mini-app",
    "deploy": "npm run build:mini-app && wrangler deploy",
    "db:init:local": "wrangler d1 execute telegram_bot_db --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute telegram_bot_db --remote --file=./schema.sql",
    "webhook:set": "node scripts/set-webhook.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "grammy": "^1.31.3",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "wrangler": "^4.81.1"
  }
}
